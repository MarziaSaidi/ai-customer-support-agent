# Database
POSTGRES_DB=support_ai
POSTGRES_USER=support_ai
POSTGRES_PASSWORD=support_ai_dev
DATABASE_URL=jdbc:postgresql://localhost:5432/support_ai

# JWT — generate a strong value with: openssl rand -base64 48
# The backend refuses to start outside local dev if this is left as the "change-me..." placeholder.
JWT_SECRET=local-dev-secret-please-override-with-a-32byte-random-value
JWT_EXPIRATION_MS=86400000

# File storage (local)
LOCAL_STORAGE_PATH=./uploads

# OpenAI — used for embeddings and chat completions
OPENAI_API_KEY=sk-your-openai-api-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
