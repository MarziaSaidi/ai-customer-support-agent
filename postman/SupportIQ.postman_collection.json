{
  "info": {
    "name": "SupportIQ API",
    "description": "SupportIQ customer support SaaS API collection. Run Auth → Login first to set token and companyId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "conversationId", "value": "" },
    { "key": "ticketId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman@test.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"User\",\n  \"companyName\": \"Postman Co\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('companyId', json.companyId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('companyId', json.companyId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "List documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/documents?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["documents"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Search documents",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": {{companyId}},\n  \"query\": \"How do refunds work?\",\n  \"limit\": 5\n}"
            },
            "url": "{{baseUrl}}/documents/search"
          }
        }
      ]
    },
    {
      "name": "Knowledge",
      "item": [
        {
          "name": "Ask AI",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": {{companyId}},\n  \"question\": \"Can I return shoes after 30 days?\"\n}"
            },
            "url": "{{baseUrl}}/knowledge/ask"
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Start widget session",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/chat/widget/sessions?companyId={{companyId}}&customerEmail=customer@test.com&customerName=Test Customer",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "widget", "sessions"],
              "query": [
                { "key": "companyId", "value": "{{companyId}}" },
                { "key": "customerEmail", "value": "customer@test.com" },
                { "key": "customerName", "value": "Test Customer" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('conversationId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Send widget message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Where is my order #48291?\"\n}"
            },
            "url": "{{baseUrl}}/chat/widget/sessions/{{conversationId}}/messages"
          }
        },
        {
          "name": "List conversations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/chat/sessions?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "sessions"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Get conversation",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/chat/sessions/{{conversationId}}?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "sessions", "{{conversationId}}"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Agent reply",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"An agent is looking into your order now.\"\n}"
            },
            "url": "{{baseUrl}}/chat/sessions/{{conversationId}}/messages"
          }
        },
        {
          "name": "Resolve conversation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chat/sessions/{{conversationId}}/resolve"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "List tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/tickets?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Create ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Postman test ticket\",\n  \"description\": \"Created from Postman collection\",\n  \"priority\": \"MEDIUM\",\n  \"customerEmail\": \"customer@test.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('ticketId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get ticket",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{ticketId}}?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{ticketId}}"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Update ticket status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/{{ticketId}}?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{ticketId}}"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Add internal note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Followed up with customer via email.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/{{ticketId}}/notes?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{ticketId}}", "notes"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["analytics"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        },
        {
          "name": "Top questions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/questions?companyId={{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "questions"],
              "query": [{ "key": "companyId", "value": "{{companyId}}" }]
            }
          }
        }
      ]
    }
  ]
}
